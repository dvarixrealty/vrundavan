rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global default-deny safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Primitive Validators
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // Role-based validation using trusted verified email credentials
    function isAdmin() {
      return isSignedIn() &&
             request.auth.token.email == "dvarixrealty@gmail.com";
    }

    // 3. Entity Schema Validators
    function isValidProperty(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.title is string && data.title.size() <= 200 &&
             data.type is string && data.type.size() <= 100 &&
             data.address is string && data.address.size() <= 500 &&
             data.price is number && data.price >= 0;
    }

    function isValidInquiry(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 120 &&
             data.email is string && data.email.size() <= 120 &&
             data.phone is string && data.phone.size() <= 40 &&
             data.message is string && data.message.size() <= 2000;
    }

    function isValidRequirement(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.fullName is string && data.fullName.size() <= 130 &&
             data.mobileNumber is string && data.mobileNumber.size() <= 40 &&
             data.lookingFor is string &&
             data.preferredCity is string && data.preferredCity.size() <= 100;
    }

    function isValidCategory(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.title is string && data.title.size() <= 100 &&
             data.description is string && data.description.size() <= 500;
    }

    function isValidAgent(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 120;
    }

    function isValidMapLocation(data) {
      return data.name is string && data.name.size() <= 100 &&
             data.x is string && data.x.size() <= 10 &&
             data.y is string && data.y.size() <= 10;
    }

    function isValidCampaignService(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.title is string && data.title.size() <= 200 &&
             data.status is string;
    }

    function isValidCampaignRequest(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.customerName is string && data.customerName.size() <= 120 &&
             data.phone is string && data.phone.size() <= 40 &&
             data.email is string && data.email.size() <= 120 &&
             data.requestedServiceId is string && data.requestedServiceId.size() <= 128 &&
             data.requestedServiceName is string && data.requestedServiceName.size() <= 200;
    }

    // 4. Match Rules for Collections
    match /properties/{propertyId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidId(propertyId) && isValidProperty(incoming());
      allow delete: if isAdmin() && isValidId(propertyId);
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidId(categoryId) && isValidCategory(incoming());
      allow delete: if isAdmin() && isValidId(categoryId);
    }

    match /agents/{agentId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidId(agentId) && isValidAgent(incoming());
      allow delete: if isAdmin() && isValidId(agentId);
    }

    match /map_locations/{locationId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidId(locationId) && isValidMapLocation(incoming());
      allow delete: if isAdmin() && isValidId(locationId);
    }

    match /inquiries/{inquiryId} {
      allow create: if isValidId(inquiryId) && isValidInquiry(incoming());
      allow read, update, delete: if isAdmin() && isValidId(inquiryId);
    }

    match /requirements/{requirementId} {
      allow create: if isValidId(requirementId) && isValidRequirement(incoming());
      allow read, update, delete: if isValidId(requirementId) && (isAdmin() || (isSignedIn() && existing().emailAddress == request.auth.token.email));
    }

    match /ai_permissions/{permissionId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin() && isValidId(permissionId);
    }

    match /ai_activity_logs/{logId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(logId);
      allow update, delete: if isAdmin() && isValidId(logId);
    }

    match /chatbot_knowledge/{knowledgeId} {
      allow read: if true; // Public or client-side visitor widget queries
      allow create, update, delete: if isSignedIn() && isValidId(knowledgeId);
    }

    match /qualification_rules/{ruleId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn() && isValidId(ruleId);
    }

    match /chatbot_audit_logs/{logId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(logId);
      allow update, delete: if isAdmin() && isValidId(logId);
    }

    match /chatbot_settings/{settingId} {
      allow read: if true; // Public widget reads config (bot personality, name)
      allow create, update, delete: if isSignedIn() && isValidId(settingId);
    }

    match /settings/{settingId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidId(settingId);
    }

    match /campaign_services/{serviceId} {
      allow read: if true;
      allow create, delete: if isAdmin() && isValidId(serviceId);
      allow update: if (isAdmin() && isValidId(serviceId)) || (isValidId(serviceId) && incoming().diff(existing()).affectedKeys().hasOnly(['views', 'clicks', 'submissions']));
    }

    match /campaign_requests/{requestId} {
      allow create: if isValidId(requestId) && isValidCampaignRequest(incoming());
      allow read, update, delete: if isAdmin() && isValidId(requestId);
    }

    match /banner_management/{bannerId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidId(bannerId);
    }

    match /hero_banners/{bannerId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidId(bannerId);
    }
  }
}
